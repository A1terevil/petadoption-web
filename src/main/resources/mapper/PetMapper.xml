<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
 PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
 "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
 <mapper namespace="petadoption.mapper.PetMapper">
 
 <select id="getAllPets" resultType="Pet">
	select * from pet 
 </select>
 
 <select id="getPetByPname" resultType="Pet">
 	select * from pet where pname = #{pname}
 </select>
 
 <delete id="deletePetByPid" parameterType="java.lang.Integer">
     delete from pet where pid = #{pid}
 </delete>
 
  <update id="updatePetByPid" parameterType="Pet">
     update pet set pname=#{pname},species=#{species},psex=#{psex},birthday=#{birthday},`condition`=#{condition},image=#{image}
      where pid=#{pid}
 </update>
 
  <insert id="insertPet" parameterType="Pet">
 	insert into pet values(null,#{pname},#{species},#{psex},#{birthday},#{condition},#{image})
 </insert>
 
 
 
 </mapper>